      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Tu perfil no será visible para empresas hasta que SAFE apruebe tu postulación y actives tu cuenta como colaborador.",
